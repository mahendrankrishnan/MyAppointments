# Copy to .env and adjust values. Docker Compose loads .env from the project root.

# PostgreSQL (used by postgres service and backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=appointments

# Backend — use host `postgres` (service name) when running via docker-compose
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/appointments
REDIS_URL=redis://redis:6379
PORT=4206
FRONTEND_URL=http://localhost:4205

# OpenAI (optional — required for "Generate with AI")
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Frontend
API_URL=http://localhost:4206
